{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.title' | trans }}{% endblock %}
{% block page_title %}⚙️ {{ 'admin.title' | trans }}{% endblock %}

{% block body %}

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card rounded-4 border-0 shadow-sm p-4 text-center">
                <div class="subject-emoji">🎨</div>
                <h5 class="fw-bold mt-3">{{ 'admin.themes' | trans }}</h5>
                <p class="text-muted">{{ 'admin.themesDescription' | trans }}</p>
                <a href="{{ path('app_theme_index') }}" class="btn btn-primary rounded-3 fw-bold">
                    {{ 'admin.manageThemes' | trans }}
                </a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card rounded-4 border-0 shadow-sm p-4 text-center">
                <div class="subject-emoji">📚</div>
                <h5 class="fw-bold mt-3">{{ 'admin.subjects' | trans }}</h5>
                <p class="text-muted">{{ 'admin.subjectsDescription' | trans }}</p>
                <a href="{{ path('app_subject_index') }}" class="btn btn-success rounded-3 fw-bold">
                    {{ 'admin.manageSubjects' | trans }}
                </a>
            </div>
        </div>
    </div>

{% endblock %}