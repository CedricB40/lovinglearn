{% extends 'base.html.twig' %}

{% block title %}{{ 'account.title' | trans }}{% endblock %}
{% block page_title %}👤 {{ 'account.title' | trans }}{% endblock %}

{% block body %}

    <div class="row g-4">

        {# Colonne gauche — Avatar #}
        <div class="col-md-3 text-center">
            <div class="card rounded-4 border-0 shadow-sm p-4">
                {% if app.user.imageName %}
                    <img src="{{ asset('images/profiles/' ~ app.user.imageName) }}"
                         alt="{{ app.user.firstname }}"
                         class="rounded-circle mx-auto d-block mb-3"
                         style="width: 120px; height: 120px; object-fit: cover;">
                {% else %}
                    <img src="{{ asset('images/profiles/default.png') }}"
                         alt="Avatar par défaut"
                         class="rounded-circle mx-auto d-block mb-3"
                         style="width: 120px; height: 120px; object-fit: cover;">
                {% endif %}
                <h5 class="fw-bold mb-0">{{ app.user.firstname }} {{ app.user.lastname }}</h5>
                <small class="text-muted">{{ app.user.email }}</small>
                <div class="mt-3">
                    {% if 'ROLE_ADMIN' in app.user.roles %}
                        <span class="badge bg-danger">👑 {{ 'account.admin' | trans }}</span>
                    {% else %}
                        <span class="badge bg-primary">👤 {{ 'account.user' | trans }}</span>
                    {% endif %}
                </div>
                <div class="mt-3">
                    <a href="{{ path('app_account_edit') }}" class="btn btn-primary rounded-3 w-100">
                        ✏️ {{ 'account.editTitle' | trans }}
                    </a>
                </div>
            </div>
        </div>

        {# Colonne droite — Informations #}
        <div class="col-md-9">
            <div class="card rounded-4 border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-4">📋 {{ 'account.myInfo' | trans }}</h5>

                <div class="row g-3">
                    <div class="col-md-6">
                        <small class="text-muted d-block">{{ 'account.firstname' | trans }}</small>
                        <p class="fw-bold mb-0">{{ app.user.firstname }}</p>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block">{{ 'account.lastname' | trans }}</small>
                        <p class="fw-bold mb-0">{{ app.user.lastname }}</p>
                    </div>
                    <div class="col-md-12">
                        <small class="text-muted d-block">{{ 'account.email' | trans }}</small>
                        <p class="fw-bold mb-0">{{ app.user.email }}</p>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block">{{ 'account.status' | trans }}</small>
                        <p class="fw-bold mb-0">
                            {% if app.user.isVerified %}
                                <span class="badge bg-success">✅ {{ 'account.verified' | trans }}</span>
                            {% else %}
                                <span class="badge bg-warning">⚠️ {{ 'account.notVerified' | trans }}</span>
                            {% endif %}
                        </p>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted d-block">{{ 'account.role' | trans }}</small>
                        <p class="fw-bold mb-0">
                            {% if 'ROLE_ADMIN' in app.user.roles %}
                                <span class="badge bg-danger">👑 {{ 'account.admin' | trans }}</span>
                            {% else %}
                                <span class="badge bg-primary">👤 {{ 'account.user' | trans }}</span>
                            {% endif %}
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </div>

{% endblock %}