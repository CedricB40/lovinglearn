<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}LovingLearn{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
        {{ importmap('app') }}
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div id="stars-bg"></div>

        <div class="d-flex min-vh-100">

            {# SIDEBAR #}
            {{ include('partials/_sidebar.html.twig') }}

            {# MAIN #}
            <div class="flex-grow-1 d-flex flex-column">

                {# TOPBAR #}
                {{ include('partials/_topbar.html.twig') }}

                {# CONTENU #}
                <div class="p-4 flex-grow-1">
                    {{ include('partials/_flash_messages.html.twig') }}
                    {% block body %}{% endblock %}
                </div>

            </div>

        </div>

        {{ include('partials/_scripts.html.twig') }}
        {% block javascripts %}{% endblock %}

    </body>
</html>