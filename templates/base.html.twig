<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}LovingLearn
			{% endblock %}

		</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
	</head>
	<body class="bg-light">

		<div
			class="d-flex min-vh-100">

			{# SIDEBAR #}
			<aside
				style="width: 240px; background-color: #6c63ff; flex-shrink: 0;">

				{# Logo #}
				<div class="p-3 border-bottom border-white border-opacity-25">
					<a href="{{ path('app_home') }}" class="text-white text-decoration-none">
						<h5 class="text-white fw-bold mb-0">🎓 LovingLearn</h5>
					</a>
					<small style="color: rgba(255,255,255,0.6);">{{ 'sidebar.tagline' | trans }}</small>
				</div>

				{# Navigation #}
				<nav class="p-2">
					<small class="d-block px-2 mb-2 text-uppercase">{{ 'sidebar.univers' | trans }}</small>
					{% if themes is defined %}
						{% for theme in themes %}
							<a href="{{ path('app_theme_show_public', {'slug': theme.slug}) }}" class="d-flex justify-content-between align-items-center text-white text-decoration-none px-3 py-2 rounded-3 mb-1 fw-bold">
								<span>{{ theme.image }}
									{{ theme.name }}</span>
								<span>▸</span>
							</a>
						{% endfor %}
					{% endif %}

					<hr style="border-color: rgba(255,255,255,0.2);">

					{% if app.user and 'ROLE_ADMIN' in app.user.roles %}
						<a href="{{ path('app_admin') }}" class="d-flex align-items-center text-decoration-none px-3 py-2 rounded-3 fw-bold" style="color: rgba(255,255,255,0.6);">
							<span>⚙️
								{{ 'sidebar.admin' | trans }}</span>
						</a>
					{% endif %}
				</nav>

			</aside>

			{# MAIN #}
			<div
				class="flex-grow-1 d-flex flex-column">

				{# TOPBAR #}
				<div class="bg-white border-bottom px-4 d-flex align-items-center justify-content-between" style="height: 60px;">
					<h5 class="fw-bold mb-0">
						{% block page_title %}Tableau de bord
						{% endblock %}
					</h5>
					<div class="d-flex gap-2 align-items-center">

						{% if app.user %}
							<a href="{{ path('app_account') }}" class="btn btn-sm btn-outline-secondary">{{ 'navBar.account' | trans }}</a>
							<a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger">{{ 'navBar.logout' | trans }}</a>
						{% else %}
							<a href="{{ path('app_register') }}" class="btn btn-sm btn-outline-primary">{{ 'navBar.signUp' | trans }}</a>
							<a href="{{ path('app_login') }}" class="btn btn-sm" style="background:#6c63ff; color:white;">{{ 'navBar.login' | trans }}</a>
						{% endif %}
					</div>
				</div>

				{# CONTENU #}
				<div
					class="p-4 flex-grow-1">

					{# Flash messages #}
					{% for message in app.flashes('success') %}
						<div class="alert alert-success rounded-3">✅
							{{ message }}</div>
					{% endfor %}
					{% for message in app.flashes('error') %}
						<div class="alert alert-danger rounded-3">❌
							{{ message }}</div>
					{% endfor %}

					{% block body %}{% endblock %}

				</div>

			</div>

		</div>

		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
		{% block javascripts %}{% endblock %}
	</body>
</html>
