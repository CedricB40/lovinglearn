{% extends 'base.html.twig' %}

{% block title %}Accueil — LovingLearn{% endblock %}
{% block page_title %}🎓 Tableau de bord{% endblock %}

{% block body %}

    {# Bannière de bienvenue #}
    <div class="p-4 mb-4 text-white rounded-4" style="background: linear-gradient(135deg, #667eea, #764ba2);">
        <h2 class="fw-bold">Bienvenue sur LovingLearn ! 🎉</h2>
        <p class="mb-0">Choisis un univers pour commencer à apprendre et jouer.</p>
    </div>

    {# Cartes thèmes dynamiques #}
    <h5 class="fw-bold mb-3">🌍 Les thèmes</h5>
    <div class="row g-3 mb-4">
        {% for theme in themes %}
            <div class="col-md-3">
                <div class="card text-center rounded-4 border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div style="font-size: 3rem;">{{ theme.image ?? '🌍' }}</div>
                        <h6 class="fw-bold mt-2">{{ theme.name }}</h6>
                        <small class="text-muted">0 sujets</small>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <p class="text-muted">Aucun thème disponible pour le moment.</p>
            </div>
        {% endfor %}
    </div>

    {# Boutons d'action #}
    <h5 class="fw-bold mb-3">⭐ Que veux-tu faire ?</h5>
    <div class="row g-3">
        <div class="col-md-3">
            <a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white" style="background:#4caf50; border-bottom: 4px solid #388e3c; font-size: 16px;">
                📚 Apprendre
            </a>
        </div>
        <div class="col-md-3">
            <a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white" style="background:#f44336; border-bottom: 4px solid #c62828; font-size: 16px;">
                ❓ Quiz
            </a>
        </div>
        <div class="col-md-3">
            <a href="{{ path('app_memory')}}" class="btn w-100 py-3 rounded-4 fw-bold text-white" style="background:#2196f3; border-bottom: 4px solid #1565c0; font-size: 16px;">
                🃏 Memory
            </a>
        </div>
        <div class="col-md-3">
            <a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white" style="background:#ff9800; border-bottom: 4px solid #e65100; font-size: 16px;">
                🏆 Classement
            </a>
        </div>
    </div>

{% endblock %}