{% extends 'base.html.twig' %}

{% block title %}
	{{ 'home.title' | trans }}
{% endblock %}
{% block page_title %}🎓
	{{ 'home.dashboard' | trans }}
{% endblock %}

{% block body %}

	{# Bannière de bienvenue #}
	<div class="p-4 mb-4 text-white rounded-4" style="background: linear-gradient(135deg, #667eea, #764ba2);">
		<h2 class="fw-bold">{{ 'home.welcome' | trans }}
			🎉</h2>
		<p class="mb-0">{{ 'home.subtitle' | trans }}</p>
	</div>

	{# Boutons d'action #}
	<h5 class="fw-bold mb-3">⭐
		{{ 'home.whatToDo' | trans }}</h5>
	<div class="row g-3">
		<div class="col-md-3">
			<a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white disabled" style="background:#4caf50; border-bottom: 4px solid #388e3c; font-size: 16px;">
				📚
				{{ 'home.learn' | trans }}
			</a>
		</div>
		<div class="col-md-3">
			<a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white disabled" style="background:#f44336; border-bottom: 4px solid #c62828; font-size: 16px;">
				❓
				{{ 'home.quiz' | trans }}
			</a>
		</div>
		<div class="col-md-3">
			<a href="{{ path('app_memory')}}" class="btn w-100 py-3 rounded-4 fw-bold text-white" style="background:#2196f3; border-bottom: 4px solid #1565c0; font-size: 16px;">
				🃏
				{{ 'home.memory' | trans }}
			</a>
		</div>
		<div class="col-md-3">
			<a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white disabled" style="background:#ff9800; border-bottom: 4px solid #e65100; font-size: 16px;">
				🏆
				{{ 'home.ranking' | trans }}
			</a>
		</div>
	</div>

{% endblock %}
