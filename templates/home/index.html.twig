{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title' | trans }}{% endblock %}
{% block page_title %}🎓 {{ 'home.dashboard' | trans }}{% endblock %}

{% block body %}

    {# Bannière de bienvenue #}
    <div class="p-4 mb-4 text-white rounded-4 banner-welcome">
        <h2 class="fw-bold">{{ 'home.welcome' | trans }} 🎉</h2>
        <p class="mb-0">{{ 'home.subtitle' | trans }}</p>
    </div>

    {# Boutons d'action #}
    <h5 class="fw-bold mb-3">⭐ {{ 'home.whatToDo' | trans }}</h5>
    <div class="row g-3">
        <div class="col-md-3">
            <a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white disabled btn-action-green">
                📚 {{ 'home.learn' | trans }}
            </a>
        </div>
        <div class="col-md-3">
            <a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white disabled btn-action-red">
                ❓ {{ 'home.quiz' | trans }}
            </a>
        </div>
        <div class="col-md-3">
            <a href="{{ path('app_memory') }}" class="btn w-100 py-3 rounded-4 fw-bold text-white btn-action-blue">
                🃏 {{ 'home.memory' | trans }}
            </a>
        </div>
        <div class="col-md-3">
            <a href="#" class="btn w-100 py-3 rounded-4 fw-bold text-white disabled btn-action-orange">
                🏆 {{ 'home.ranking' | trans }}
            </a>
        </div>
    </div>

{% endblock %}