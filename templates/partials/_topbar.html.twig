{# TOPBAR #}
<div class="topbar px-4 d-flex align-items-center justify-content-between">

    <div class="d-flex align-items-center gap-3">
        {# Bouton burger - visible uniquement sur mobile #}
        <button class="btn btn-sm d-lg-none sidebar-toggler"
                type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#sidebarMobile">
            ☰
        </button>

        <h5 class="fw-bold mb-0">
            {% block page_title %}Tableau de bord{% endblock %}
        </h5>
    </div>

    <div class="d-flex gap-2 align-items-center">
        {% if app.user %}
            <a href="{{ path('app_account') }}" class="btn btn-sm btn-outline-secondary">{{ 'navBar.account' | trans }}</a>
            <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger">{{ 'navBar.logout' | trans }}</a>
        {% else %}
            <a href="{{ path('app_register') }}" class="btn btn-sm btn-outline-primary">{{ 'navBar.signUp' | trans }}</a>
            <a href="{{ path('app_login') }}" class="btn btn-sm btn-primary">{{ 'navBar.login' | trans }}</a>
        {% endif %}
    </div>

</div>