{% extends 'base.html.twig' %}

{% block title %}{{ 'resetPassword.title' | trans }}{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <h1>{{ 'resetPassword.title' | trans }}</h1>

    {{ form_start(requestForm) }}
        {{ form_row(requestForm.email, { label: 'loginForm.email' | trans }) }}
        <div>
            <small>
                {{ 'resetPassword.instruction' | trans }}
            </small>
        </div>

        <button class="btn btn-primary">{{ 'resetPassword.send' | trans }}</button>
    {{ form_end(requestForm) }}
{% endblock %}