{% extends 'base.html.twig' %}

{% block title %}{{ 'resetPassword.title' | trans }}{% endblock %}

{% block body %}
    <h1>{{ 'resetPassword.title' | trans }}</h1>

    {{ form_start(resetForm) }}
        {{ form_row(resetForm.plainPassword.first, { label: 'resetPassword.newPassword' | trans }) }}
        {{ form_row(resetForm.plainPassword.second, { label: 'resetPassword.repeat' | trans }) }}
        <button class="btn btn-primary">{{ 'resetPassword.reset' | trans }}</button>
    {{ form_end(resetForm) }}
{% endblock %}