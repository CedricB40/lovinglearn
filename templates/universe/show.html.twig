{% extends 'base.html.twig' %}

{% block title %}Universe{% endblock %}

{% block body %}
    <h1>Universe</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ universe.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ universe.name }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ universe.slug }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ universe.description }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>{{ universe.image }}</td>
            </tr>
            <tr>
                <th>Color</th>
                <td>{{ universe.color }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_universe_index') }}">back to list</a>

    <a href="{{ path('app_universe_edit', {'id': universe.id}) }}">edit</a>

    {{ include('universe/_delete_form.html.twig') }}
{% endblock %}
