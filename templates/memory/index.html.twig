{% extends 'base.html.twig' %}

{% block title %}Memory - Espace{% endblock %}

{% block page_title %}🚀 Memory - Système Solaire{% endblock %}

{% block body %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Retrouve les paires !</h2>
    <div class="d-flex gap-3 align-items-center">
        <span class="badge rounded-pill bg-primary fs-6">Coups : <span id="counter">0</span></span>
        <button class="btn btn-outline-secondary btn-sm" onclick="restartGame()">🔄 Rejouer</button>
    </div>
</div>

<div id="memory-grid" class="d-flex flex-wrap gap-3 justify-content-center">
</div>

<div id="victory-message" class="text-center mt-4 d-none">
    <div class="alert alert-success fs-4">
        🎉 Bravo ! Tu as trouvé toutes les paires en <strong><span id="final-counter"></span></strong> coups !
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
    const planets = {{ planets | json_encode | raw }};

    let cards = [];
    let flippedCards = [];
    let matchedPairs = 0;
    let counter = 0;
    let lockBoard = false;

    function createCards() {
        // Créer les paires : 1 carte image + 1 carte nom pour chaque planète
        planets.forEach(planet => {
            cards.push({ type: 'image', value: planet.name, image: planet.image });
            cards.push({ type: 'name', value: planet.name, image: planet.image });
        });

        // Mélanger les cartes
        cards.sort(() => Math.random() - 0.5);
    }

    function renderCards() {
        const grid = document.getElementById('memory-grid');
        grid.innerHTML = '';

        cards.forEach((card, index) => {
            const cardEl = document.createElement('div');
            cardEl.classList.add('memory-card');
            cardEl.dataset.index = index;
            cardEl.dataset.value = card.value;

            cardEl.innerHTML = `
                <div class="card-inner">
                    <div class="card-front">❓</div>
                    <div class="card-back">
                        ${card.type === 'image'
                            ? `<img src="/images/${card.image}" alt="${card.value}">`
                            : `<span>${card.value}</span>`
                        }
                    </div>
                </div>
            `;

            cardEl.addEventListener('click', () => flipCard(cardEl));
            grid.appendChild(cardEl);
        });
    }

    function flipCard(cardEl) {
        if (lockBoard) return;
        if (cardEl.classList.contains('flipped')) return;
        if (cardEl.classList.contains('matched')) return;

        cardEl.classList.add('flipped');
        flippedCards.push(cardEl);

        if (flippedCards.length === 2) {
            lockBoard = true;
            counter++;
            document.getElementById('counter').textContent = counter;
            checkMatch();
        }
    }

    function checkMatch() {
        const [card1, card2] = flippedCards;

        if (card1.dataset.value === card2.dataset.value) {
            card1.classList.add('matched');
            card2.classList.add('matched');
            matchedPairs++;
            flippedCards = [];
            lockBoard = false;

            if (matchedPairs === planets.length) {
                document.getElementById('final-counter').textContent = counter;
                document.getElementById('victory-message').classList.remove('d-none');
            }
        } else {
            setTimeout(() => {
                card1.classList.remove('flipped');
                card2.classList.remove('flipped');
                flippedCards = [];
                lockBoard = false;
            }, 1000);
        }
    }

    function restartGame() {
        cards = [];
        flippedCards = [];
        matchedPairs = 0;
        counter = 0;
        lockBoard = false;
        document.getElementById('counter').textContent = 0;
        document.getElementById('victory-message').classList.add('d-none');
        createCards();
        renderCards();
    }

    createCards();
    renderCards();
</script>

<style>
    .memory-card {
        width: 120px;
        height: 120px;
        cursor: pointer;
        perspective: 1000px;
    }

    .card-inner {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.5s;
    }

    .memory-card.flipped .card-inner,
    .memory-card.matched .card-inner {
        transform: rotateY(180deg);
    }

    .card-front, .card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    .card-front {
        background: #6c63ff;
        color: white;
    }

    .card-back {
        background: white;
        transform: rotateY(180deg);
        border: 2px solid #6c63ff;
    }

    .card-back img {
        width: 80px;
        height: 80px;
        object-fit: contain;
    }

    .card-back span {
        font-size: 0.9rem;
        font-weight: bold;
        color: #6c63ff;
        text-align: center;
        padding: 5px;
    }

    .memory-card.matched .card-back {
        background: #e8f5e9;
        border-color: #4caf50;
    }
</style>
{% endblock %}