{% extends 'base.html.twig' %}

{% block title %}{{ theme.name }} — Memory{% endblock %}
{% block page_title %}🃏 {{ theme.name }}{% endblock %}

{% block body %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>{{ 'memory.findPairs' | trans }}</h2>
        <div class="d-flex gap-3 align-items-center">
            <span class="badge rounded-pill bg-primary fs-6">
                {{ 'memory.moves' | trans }} : <span id="counter">0</span>
            </span>
            <button class="btn btn-outline-secondary btn-sm" onclick="restartGame()">
                🔄 {{ 'memory.replay' | trans }}
            </button>
            <a href="{{ path('app_memory_modes', {'slug': theme.slug}) }}"
               class="btn btn-outline-secondary btn-sm">
                ← {{ 'memory.backToModes' | trans }}
            </a>
        </div>
    </div>

    <div id="memory-grid" class="d-flex flex-wrap gap-3 justify-content-center"
         style="max-width: 720px; margin: 0 auto;"></div>

    <div id="victory-message" class="text-center mt-4 d-none">
        <div class="alert alert-success fs-4">
            🎉 {{ 'memory.victory' | trans }}
            <strong><span id="final-counter"></span></strong>
            {{ 'memory.moves' | trans }} !
        </div>
    </div>

{% endblock %}

{% block javascripts %}
<script>
    (function() {
        var cardsData = {{ cards | json_encode | raw }};
        var mode = "{{ mode }}";
        var imageBasePath = "{{ asset('images/') }}";

        var deck         = [];
        var flippedCards = [];
        var matchedPairs = 0;
        var counter      = 0;
        var lockBoard    = false;

        function createDeck() {
            deck = [];
            if (mode === 'nom-image') {
                cardsData.forEach(function(card) {
                    deck.push({ type: 'image', value: card.name, image: card.image });
                    deck.push({ type: 'name',  value: card.name, image: card.image });
                });
            } else {
                cardsData.forEach(function(card) {
                    deck.push({ type: 'image', value: card.name, image: card.image });
                    deck.push({ type: 'image', value: card.name, image: card.image });
                });
            }
            deck.sort(function() { return Math.random() - 0.5; });
        }

        function renderDeck() {
            var grid = document.getElementById('memory-grid');
            grid.innerHTML = '';

            deck.forEach(function(card, index) {
                var cardEl = document.createElement('div');
                cardEl.classList.add('memory-card');
                cardEl.dataset.index = index;

                cardEl.innerHTML =
                    '<div class="card-inner">' +
                        '<div class="card-front">❓</div>' +
                        '<div class="card-back"></div>' +
                    '</div>';

                cardEl.addEventListener('click', function() { flipCard(cardEl); });
                grid.appendChild(cardEl);
            });
        }

        function speakCardName(text) {
            if (!window.speechSynthesis) return;
            window.speechSynthesis.cancel();
            var utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'fr-FR';
            utterance.rate = 0.9;
            window.speechSynthesis.speak(utterance);
        }

        function flipCard(cardEl) {
            if (lockBoard) return;
            if (cardEl.classList.contains('flipped')) return;
            if (cardEl.classList.contains('matched')) return;

            var index = parseInt(cardEl.dataset.index, 10);
            var card = deck[index];

            var backEl = cardEl.querySelector('.card-back');
            backEl.innerHTML = (card.type === 'image')
                ? '<img src="' + imageBasePath + card.image + '" alt="' + card.value + '">'
                : '<span>' + card.value + '</span>';

            speakCardName(card.value);

            cardEl.classList.add('flipped');
            flippedCards.push({ el: cardEl, index: index });

            if (flippedCards.length === 2) {
                lockBoard = true;
                counter++;
                document.getElementById('counter').textContent = counter;
                checkMatch();
            }
        }

        function checkMatch() {
            var first  = flippedCards[0];
            var second = flippedCards[1];

            var isMatch = deck[first.index].value === deck[second.index].value
                       && first.index !== second.index;

            if (isMatch) {
                first.el.classList.add('matched');
                second.el.classList.add('matched');
                matchedPairs++;
                flippedCards = [];
                lockBoard    = false;

                if (matchedPairs === cardsData.length) {
                    document.getElementById('final-counter').textContent = counter;
                    document.getElementById('victory-message').classList.remove('d-none');
                }
            } else {
                setTimeout(function() {
                    first.el.classList.remove('flipped');
                    second.el.classList.remove('flipped');
                    first.el.querySelector('.card-back').innerHTML = '';
                    second.el.querySelector('.card-back').innerHTML = '';
                    flippedCards = [];
                    lockBoard    = false;
                }, 1000);
            }
        }

        function restartGame() {
            deck         = [];
            flippedCards = [];
            matchedPairs = 0;
            counter      = 0;
            lockBoard    = false;
            document.getElementById('counter').textContent = 0;
            document.getElementById('victory-message').classList.add('d-none');
            createDeck();
            renderDeck();
        }

        window.restartGame = restartGame;

        createDeck();
        renderDeck();
    })();
</script>
{% endblock %}