{% extends 'base.html.twig' %}

{% block title %}{{ subject.name }}{% endblock %}
{% block page_title %}🪐 {{ subject.name }}{% endblock %}

{% block body %}

<div class="row g-4">

    {# Image + infos principales #}
    <div class="col-md-4">
        <div class="card rounded-4 border-0 shadow-sm text-center p-4">
            {% if subject.image %}
                <img src="/images/{{ subject.image }}" alt="{{ subject.name }}"
                     style="width: 180px; height: 180px; object-fit: contain; margin: 0 auto;">
            {% else %}
                <div style="font-size: 5rem;">🌍</div>
            {% endif %}
            <h3 class="fw-bold mt-3">{{ subject.name }}</h3>
            <p class="text-muted">{{ subject.description }}</p>
            <span class="badge rounded-pill" style="background:#6c63ff; color:white;">
                {{ subject.theme.name }}
            </span>
        </div>
    </div>

    {# Contenu détaillé #}
    <div class="col-md-8">
        <div class="card rounded-4 border-0 shadow-sm p-4 h-100">
            <h5 class="fw-bold mb-3">📖 En savoir plus</h5>
            <p class="text-muted" style="line-height: 1.8;">{{ subject.content }}</p>
        </div>
    </div>

</div>

{# Boutons admin si connecté #}
{% if app.user and 'ROLE_ADMIN' in app.user.roles %}
    <div class="d-flex gap-2 mt-4">
        <a href="{{ path('app_subject_edit', {'id': subject.id}) }}" class="btn btn-warning rounded-3">✏️ Modifier</a>
        {{ include('subject/_delete_form.html.twig') }}
    </div>
{% endif %}

<div class="mt-3">
    <a href="{{ path('app_subject_index') }}" class="btn btn-outline-secondary rounded-3">← Retour à la liste</a>
</div>

{% endblock %}