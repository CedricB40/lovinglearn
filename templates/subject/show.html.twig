{% extends 'base.html.twig' %}

{% block title %}{{ subject.name }}{% endblock %}
{% block page_title %}👁️ {{ subject.name }}{% endblock %}

{% block body %}

    <div class="card rounded-4 border-0 shadow-sm p-4" style="max-width: 600px;">
        <table class="table">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ subject.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ subject.name }}</td>
                </tr>
                <tr>
                    <th>Slug</th>
                    <td>{{ subject.slug }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ subject.description }}</td>
                </tr>
                <tr>
                    <th>Contenu</th>
                    <td>{{ subject.content }}</td>
                </tr>
                <tr>
                    <th>Image</th>
                    <td>{{ subject.image }}</td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex gap-2">
            <a href="{{ path('app_subject_index') }}" class="btn btn-secondary rounded-3">← Retour à la liste</a>
            <a href="{{ path('app_subject_edit', {'id': subject.id}) }}" class="btn btn-warning rounded-3">✏️ Modifier</a>
        </div>

        <hr>
        {{ include('subject/_delete_form.html.twig') }}
    </div>

{% endblock %}