<form method="post" action="{{ path('app_theme_delete', {'id': theme.id}) }}" onsubmit="return confirm('{{ 'theme.delete.confirm' | trans }}');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ theme.id) }}">
    <button class="btn btn-danger rounded-3">🗑️ {{ 'theme.delete.button' | trans }}</button>
</form>