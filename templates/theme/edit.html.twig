{% extends 'base.html.twig' %}

{% block title %}{{ 'theme.edit.title' | trans }}{% endblock %}
{% block page_title %}✏️ {{ 'theme.edit.title' | trans }}{% endblock %}

{% block body %}

    <div class="card rounded-4 border-0 shadow-sm p-4" style="max-width: 600px;">
        {{ include('theme/_form.html.twig', {'button_label': 'theme.edit.button' | trans}) }}
        <a href="{{ path('app_theme_index') }}" class="btn btn-secondary rounded-3 mt-2">{{ 'theme.show.back' | trans }}</a>
        <hr>
        {{ include('theme/_delete_form.html.twig') }}
    </div>

{% endblock %}