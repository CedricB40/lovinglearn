{% extends 'base.html.twig' %}

{% block title %}{{ theme.name }}{% endblock %}
{% block page_title %}👁️ {{ theme.name }}{% endblock %}

{% block body %}

    <div class="card rounded-4 border-0 shadow-sm p-4" style="max-width: 600px;">
        <table class="table">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ theme.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ theme.name }}</td>
                </tr>
                <tr>
                    <th>Slug</th>
                    <td>{{ theme.slug }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ theme.description }}</td>
                </tr>
                <tr>
                    <th>Image</th>
                    <td>{{ theme.image }}</td>
                </tr>
                <tr>
                    <th>Couleur</th>
                    <td>
                        <span class="badge rounded-pill" style="background: {{ theme.color }};">{{ theme.color }}</span>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="d-flex gap-2">
            <a href="{{ path('app_theme_index') }}" class="btn btn-secondary rounded-3">← Retour à la liste</a>
            <a href="{{ path('app_theme_edit', {'id': theme.id}) }}" class="btn btn-warning rounded-3">✏️ Modifier</a>
        </div>

        <hr>
        {{ include('theme/_delete_form.html.twig') }}
    </div>

{% endblock %}